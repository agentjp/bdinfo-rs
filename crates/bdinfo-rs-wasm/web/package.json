{
  "name": "@bdinfo-rs/wasm",
  "version": "1.1.0",
  "type": "module",
  "sideEffects": [
    "./dist/worker.js",
    "./pkg/*.js"
  ],
  "description": "In-browser Blu-ray disc analyzer — the bdinfo-rs measured scan compiled to WebAssembly, run off the main thread in a Web Worker over a webkitdirectory-picked BDMV folder.",
  "license": "LGPL-2.1-or-later",
  "author": "bdinfo-rs contributors (https://github.com/agentjp/bdinfo-rs)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentjp/bdinfo-rs.git",
    "directory": "crates/bdinfo-rs-wasm/web"
  },
  "homepage": "https://github.com/agentjp/bdinfo-rs#readme",
  "bugs": "https://github.com/agentjp/bdinfo-rs/issues",
  "keywords": [
    "blu-ray",
    "bdinfo",
    "bdmv",
    "m2ts",
    "wasm",
    "webassembly",
    "browser",
    "client-side",
    "web-worker"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "module": "./dist/analyze.js",
  "types": "./dist/analyze.d.ts",
  "exports": {
    ".": {
      "types": "./dist/analyze.d.ts",
      "import": "./dist/analyze.js"
    },
    "./wasm": {
      "types": "./pkg/bdinfo_rs_wasm.d.ts",
      "import": "./pkg/bdinfo_rs_wasm.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/analyze.js",
    "dist/analyze.d.ts",
    "dist/worker.js",
    "pkg",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build:wasm": "node build.mjs",
    "build:ts": "tsc -p tsconfig.json && tsc -p tsconfig.worker.json",
    "build": "npm run build:wasm && npm run build:ts",
    "dev": "node dev.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "size": "node check-size.mjs",
    "check": "biome check .",
    "format": "biome check --write .",
    "test:node": "node test/parity.node.mjs",
    "test:chrome": "node test/parity.chrome.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "binaryen": "^130.0.0",
    "playwright-core": "^1",
    "typescript": "^6"
  }
}
